<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.experiment2.mapper.LoginUserMapper">

    <resultMap id="LoginUserMap" type="LoginUser">
        <id property="id" column="id" />
        <result property="username" column="username" />
        <result property="password" column="password" />
        <result property="email" column="email" />
        <result property="birthday" column="birthday" />
        <result property="money" column="money" />
        <result property="avatar" column="avatar" />
    </resultMap>

    <select id="findByUsername" parameterType="string" resultMap="LoginUserMap">
        select
            id,
            name as username,
            password,
            email,
            date_format(birthday, '%Y-%m-%d') as birthday,
            money,
            avatar
        from login_user
        where name = #{username}
    </select>

    <insert id="insert" parameterType="LoginUser" useGeneratedKeys="true" keyProperty="id">
        insert into login_user (name, password, email, birthday, money, avatar)
        values (#{username}, #{password}, #{email}, #{birthday}, #{money}, #{avatar})
    </insert>

    <update id="updatePassword">
        update login_user
        set password = #{password}
        where name = #{username}
    </update>
</mapper>
